; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DREAMERS"
config/description="Metal Max Returns HD-2D 复刻 - 废土冒险RPG"
config/version="v0.10"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://resource/tilesets/ff90dfe80d394faaa685776e4d7901ff_1507863071.png"

[autoload]

AttackData="*res://scripts/data/attack_data.gd"
PlayerData="*res://scripts/data/player_data.gd"
GameFlow="*res://scripts/autoload/game_flow.gd"
GameData="*res://scripts/autoload/game_data.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
TankSystem="*res://scripts/autoload/tank_system.gd"
SaveSystem="*res://scripts/autoload/save_system.gd"
BountySystem="*res://scripts/autoload/bounty_system.gd"
BattleEffects="*res://scripts/system/battle_effects.gd"
ShopData="*res://scripts/data/shop_data.gd"
NPCData="*res://scripts/data/npc_data.gd"
TankEquipData="*res://scripts/data/tank_equipment_data.gd"
DialogueManager="*res://scripts/autoload/dialogue_manager.gd"
SkillData="*res://scripts/autoload/skill_data.gd"
CDeviceSystem="*res://scripts/autoload/c_device_system.gd"
StatusEffectSystem="*res://scripts/autoload/status_effect_system.gd"
LevelUpSystem="*res://scripts/autoload/level_up_system.gd"
QuestSystem="*res://scripts/autoload/quest_system.gd"
ItemDropSystem="*res://scripts/autoload/item_drop_system.gd"
PartyManager="*res://scripts/autoload/party_manager.gd"
GameTimeSystem="*res://scripts/autoload/game_time_system.gd"
AchievementSystem="*res://scripts/autoload/achievement_system.gd"
CraftingSystem="*res://scripts/autoload/crafting_system.gd"
SceneTransitionManager="*res://scripts/autoload/scene_transition_manager.gd"
EnemyAI="*res://scripts/autoload/enemy_ai.gd"
BattleBalance="*res://scripts/autoload/battle_balance.gd"
TankBattleSystem="*res://scripts/autoload/tank_battle_system.gd"
HunterRankSystem="*res://scripts/autoload/hunter_rank_system.gd"
BgmManager="*res://scripts/autoload/bgm_manager.gd"
SfxManager="*res://scripts/autoload/sfx_manager.gd"
SceneFadeTransition="*res://scenes/ui/scene_fade_transition.tscn"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

